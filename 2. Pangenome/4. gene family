#!/bin/bash

###############################################################################
# Gene Family Analysis Pipeline (OrthoFinder)
#
# Project: Tabasco Pangenome Analysis
# Author: Lidong
# Date: 2026-06-07
# Version: 1.0
#
# Description:
#    This script performs gene family clustering analysis using OrthoFinder.
#    It identifies orthogroups across multiple genomes, providing core gene
#    families, pan gene families, and species-specific gene annotations.
###############################################################################

# =============================================================================
# 1. Global Configurations & Environment
# =============================================================================
# OrthoFinder Settings
ORTHOFINDER="./OrthoFinder-2.5.5/orthofinder.py"

# Input/Output
INPUT_DIR="./all.pro"           # Directory containing proteome FASTA files
OUTPUT_DIR="./OrthoFinder_Results"

# Resource Allocation
THREADS=20                      # -t: BLAST threads
BLAST_THREADS=20                # -a: BLAST threads for analysis

# =============================================================================
# 2. Pre-flight Checks
# =============================================================================
echo "[$(date)] INFO: Starting Gene Family Analysis Pipeline..."

if [ ! -f "${ORTHOFINDER}" ]; then
    echo "ERROR: OrthoFinder not found at ${ORTHOFINDER}"
    echo "Please check the path to orthofinder.py"
    exit 1
fi

if [ ! -d "${INPUT_DIR}" ]; then
    echo "ERROR: Input directory ${INPUT_DIR} not found!"
    echo "Please ensure the directory contains proteome FASTA files"
    exit 1
fi

# Create output directory if needed
if [ ! -d "${OUTPUT_DIR}" ]; then
    echo "INFO: Creating output directory: ${OUTPUT_DIR}"
    mkdir -p "${OUTPUT_DIR}"
fi

# =============================================================================
# 3. Execution: OrthoFinder Gene Family Clustering
# =============================================================================
echo "[$(date)] STAGE: Running OrthoFinder..."

python ${ORTHOFINDER} \
    -t ${THREADS} \
    -a ${BLAST_THREADS} \
    -f ${INPUT_DIR} \
    -o ${OUTPUT_DIR}

# =============================================================================
# 4. Pipeline Completion & Summary
# =============================================================================
if [ $? -eq 0 ]; then
    echo "-----------------------------------------------------------------------"
    echo "Gene Family Analysis Completed Successfully!"
    echo "Timestamp: $(date)"
    echo "Output Location: ${OUTPUT_DIR}"
    echo ""
    echo "Key Output Files:"
    echo "  - Orthogroups.tsv              (Gene family assignments)"
    echo "  - Orthogroups_UnassignedGenes.tsv"
    echo "  - Comparative_Statistics.tsv   (Core/Pan gene statistics)"
    echo "  - Orthologues_stats_*.tsv      (Ortholog statistics)"
    echo "  - Species_Tree/                 (Phylogenetic tree)"
    echo "-----------------------------------------------------------------------"
else
    echo "ERROR: OrthoFinder pipeline failed. Check logs for details."
    exit 1
fi
