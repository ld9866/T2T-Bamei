#!/bin/bash

###############################################################################
# Genome Annotation & Transcript Processing Pipeline (EGAPx + GFF utils)
#
# Project: Tabasco Pangenome Analysis
# Author: Lidong
# Date: 2026-06-07
# Version: 1.0
#
# Description:
#   This pipeline performs:
#     1. Genome annotation using EGAPx (RNA-seq + protein evidence)
#     2. Extraction of protein-coding gene locations (BED format)
#     3. Extraction of protein-coding gene lists
#     4. Generation of longest CDS / protein sequences from the annotation
#
# Dependencies:
#   - EGAPx (with Singularity)
#   - Python 3 + Biopython
#   - awk, grep
###############################################################################

# =============================================================================
# 1. Global Configurations & Environment
# =============================================================================
# EGAPx Settings
EGAPX_SCRIPT="/path/to/egapx/ui/egapx.py"
CONFIG_FILE="example.RNA.Protein.yaml"
EXECUTOR="singularity"

# Input/Output
WORKSPACE_DIR="example.all"
OUTPUT_DIR="example.all"
LOCAL_CACHE="/path/to/egapx/local_cache"

# Annotation Input (for post-processing)
COMPLETE_GENOME_FASTA="complete.genomic.fa"
COMPLETE_GENOME_GFF="complete.genomic.gff"

# Longest CDS extraction script
LONGEST_CDS_SCRIPT="./genome_gtf_long_cds.py"

# Resource Allocation
THREADS=20

# =============================================================================
# 2. Pre-flight Checks
# =============================================================================
echo "[$(date)] INFO: Starting Genome Annotation Pipeline..."

# Check EGAPx script
if [ ! -f "${EGAPX_SCRIPT}" ]; then
    echo "ERROR: EGAPx script not found at ${EGAPX_SCRIPT}"
    exit 1
fi

# Check config file
if [ ! -f "${CONFIG_FILE}" ]; then
    echo "ERROR: Config file ${CONFIG_FILE} not found!"
    exit 1
fi

# Create workspace if needed
if [ ! -d "${WORKSPACE_DIR}" ]; then
    echo "INFO: Creating workspace directory: ${WORKSPACE_DIR}"
    mkdir -p "${WORKSPACE_DIR}"
fi

# =============================================================================
# 3. Step 1: Genome Annotation with EGAPx
# =============================================================================
echo "[$(date)] STAGE 1/4: Running EGAPx genome annotation..."

python3 ${EGAPX_SCRIPT} ${CONFIG_FILE} \
    -e ${EXECUTOR} \
    -w ${WORKSPACE_DIR} \
    -o ${OUTPUT_DIR} \
    -lc ${LOCAL_CACHE}

if [ $? -ne 0 ]; then
    echo "ERROR: EGAPx annotation failed!"
    exit 1
fi

echo "[$(date)] INFO: EGAPx annotation completed"

# =============================================================================
# 4. Step 2: Extract Protein-Coding Gene Locations (BED Format)
# =============================================================================
echo "[$(date)] STAGE 2/4: Extracting protein-coding gene locations (BED)..."

awk '$3=="gene" && /gene_biotype=protein_coding/ {print $1"\t"$4"\t"$5"\t"$7}' \
    ${COMPLETE_GENOME_GFF} > gene.protein_coding_genes.bed

if [ $? -ne 0 ]; then
    echo "ERROR: Failed to extract BED locations!"
    exit 1
fi

echo "[$(date)] INFO: BED file generated: gene.protein_coding_genes.bed"

# =============================================================================
# 5. Step 3: Extract Complete Protein-Coding Genes (GFF + Gene List)
# =============================================================================
echo "[$(date)] STAGE 3/4: Extracting complete protein-coding gene records..."

# Extract all rows with gene_biotype=protein_coding
awk '$3=="gene" && /gene_biotype=protein_coding/' ${COMPLETE_GENOME_GFF} > protein_coding_genes.gff

# Extract gene names (assuming Name=...; format)
awk -F'Name=' '{split($2, a, ";"); print a[1]}' protein_coding_genes.gff > gene.list

# Filter genes with 'egapxtmp_' prefix (optional)
grep '^egapxtmp_' gene.list > egapxtmp_genes.list

echo "[$(date)] INFO: Extracted $(wc -l < gene.list) protein-coding genes"
echo "[$(date)] INFO: Found $(wc -l < egapxtmp_genes.list) egapxtmp-prefixed genes"

# =============================================================================
# 6. Step 4: Extract Longest Transcript Sequences
# =============================================================================
echo "[$(date)] STAGE 4/4: Extracting longest CDS / protein sequences..."

if [ ! -f "${LONGEST_CDS_SCRIPT}" ]; then
    echo "ERROR: Longest CDS script not found at ${LONGEST_CDS_SCRIPT}"
    exit 1
fi

python3 ${LONGEST_CDS_SCRIPT} ${COMPLETE_GENOME_FASTA} ${COMPLETE_GENOME_GFF}

if [ $? -ne 0 ]; then
    echo "ERROR: Longest CDS extraction failed!"
    exit 1
fi

echo "[$(date)] INFO: Longest CDS extraction completed"

# =============================================================================
# 7. Pipeline Completion & Summary
# =============================================================================
if [ $? -eq 0 ]; then
    echo "-----------------------------------------------------------------------"
    echo "Genome Annotation Pipeline Completed Successfully!"
    echo "Timestamp: $(date)"
    echo "Output Files:"
    echo "  - EGAPx results: ${OUTPUT_DIR}/"
    echo "  - gene.protein_coding_genes.bed"
    echo "  - protein_coding_genes.gff"
    echo "  - gene.list / egapxtmp_genes.list"
    echo "  - out1.fa (longest CDS / protein sequences)"
    echo "-----------------------------------------------------------------------"
else
    echo "ERROR: Pipeline failed. Check logs for details."
    exit 1
fi
